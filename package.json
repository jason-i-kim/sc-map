{
	"name": "sc-map",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bunx --bun vite dev",
		"build": "bunx --bun vite build",
		"preview": "bunx --bun vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"migrate": "bun scripts/migrate.ts",
		"test": "bun test .test.ts",
		"test:integration": "SQL_URL=postgres://sc_map:sc_map@localhost:5432/sc_map_test bun --config=bunfig.integration.toml test .integration.spec.ts",
		"storybook": "bunx --bun storybook dev -p 6006",
		"build-storybook": "bunx --bun storybook build"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@storybook/sveltekit": "10.3.0",
		"@sveltejs/adapter-node": "^5.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/bun": "^1.3.10",
		"@types/node": "^22",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"storybook": "10.3.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@googlemaps/js-api-loader": "^2.0.2",
		"@tanstack/svelte-query": "^6.1.1",
		"zod": "^4.3.6"
	}
}
