# Cloudflared tunnel token — get this from your Cloudflare Zero Trust dashboard
CLOUDFLARED_TOKEN=your_cloudflared_tunnel_token

# Baked into the client bundle at build time — required when running docker compose build
PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id

# Runtime secrets — never commit these
SESSION_SECRET=change_me_to_a_long_random_string
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://yourdomain.com/auth/discord/callback
DISCORD_GUILD_ID=your_discord_guild_id
DISCORD_GOATED_ROLE_ID=your_discord_role_id

# App origin — must match the URL users hit (used by SvelteKit for CSRF protection)
ORIGIN=https://yourdomain.com
